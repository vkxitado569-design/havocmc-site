<div id="toast">Copiado!</div>

<script>
/* ── PARTICLES ── */
for(let i=0;i<20;i++){
  const p=document.createElement('div');
  p.className='particle';
  p.style.cssText=`left:${Math.random()*100}vw;bottom:-4px;animation-duration:${7+Math.random()*14}s;animation-delay:${Math.random()*10}s;width:${1+Math.random()*2}px;height:${1+Math.random()*2}px`;
  document.body.appendChild(p);
}

/* ── LOADING TEXT CYCLE ── */
const loadMsgs=['Iniciando servidor...','import anarchy...','Carregando produtos...','Configurando ambiente...','Pronto!'];
let li=0;
const ltEl=document.getElementById('loading-text');
const ltInterval=setInterval(()=>{
  li++;
  if(li<loadMsgs.length)ltEl.textContent=loadMsgs[li];
  else clearInterval(ltInterval);
},480);

/* ── SPLASH → APP ── */
setTimeout(()=>{
  const splash=document.getElementById('splash');
  const app=document.getElementById('app');
  splash.classList.add('hide');
  setTimeout(()=>{
    splash.style.display='none';
    app.classList.add('show');
  },650);
},2800);

/* ── UTILS ── */
function copiarIP(){
  navigator.clipboard.writeText('play.havocmc.com.br').catch(()=>{});
  showToast('IP copiado: play.havocmc.com.br');
}
function comprar(nome){showToast('Redirecionando: '+nome);}
function showToast(msg){
  const t=document.getElementById('toast');
  t.childNodes[t.childNodes.length-1].textContent=' '+msg;
  t.classList.add('show');
  clearTimeout(t._timer);
  t._timer=setTimeout(()=>t.classList.remove('show'),2800);
}
function toggleFaq(btn){
  const item=btn.closest('.faq-item');
  const isOpen=item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(el=>el.classList.remove('open'));
  if(!isOpen)item.classList.add('open');
}

/* ── NAV SCROLL HIGHLIGHT ── */
const sections=document.querySelectorAll('section[id]');
window.addEventListener('scroll',()=>{
  let current='';
  sections.forEach(s=>{if(window.scrollY>=s.offsetTop-100)current=s.id;});
  document.querySelectorAll('.nav-links a').forEach(a=>{
    a.style.color=a.getAttribute('href')==='#'+current?'var(--p3)':'';
  });
});
</script>
